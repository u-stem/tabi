{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sugara",
  "version": "0.1.0",
  "identifier": "app.sugara.desktop",
  "build": {
    "devUrl": "https://sugara.vercel.app",
    "frontendDist": "https://sugara.vercel.app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sugara",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "visible": false,
        "backgroundColor": "#09090b",
        "userAgent": "sugara-desktop/0.1.0"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "nsis", "updater"],
    "windows": {
      "nsis": {
        "languages": ["Japanese"],
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMkE0QzUxMDU2QjU2QTIKUldTaVZtc0ZVVXdxc2QyZnRIVlY0bUZVQU1zL3pvUXZDVDlaZDl1WnRXcUhZWGZoYXZrYzZiWUMK",
      "endpoints": [
        "https://github.com/u-stem/sugara-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
